DNS_ENGINE=adguardhome

# ──────────────────────────────────────────────────────────
# Infrastructure - Variables d'environnement
# ──────────────────────────────────────────────────────────

# Fuseau horaire
TZ=Europe/Paris

# IP de l'hôte Docker (Carcharoth)
SERVER_IP=192.168.1.3

# Domaine DNS public (Let's Encrypt DNS-01)
DOMAIN=ghosthaven.org

# ──────────────────────────────────────────────────────────
# Let's Encrypt ACME Configuration
# ──────────────────────────────────────────────────────────
ACME_EMAIL=fontaine906@gmail.com

# Cloudflare API Token (DNS:Edit sur ghosthaven.org)
CF_DNS_API_TOKEN=cfut_vP9yMwaogMnJ2p7Wa8ypXtaNrXyfqfYzB5lDHsIs8e5d31df

# ──────────────────────────────────────────────────────────
# Services Configuration
# ──────────────────────────────────────────────────────────

# AdGuard Home - Port UI
ADGUARD_PORT=8066

# Squid Proxy - Port TCP client proxy
SQUID_PORT=3128

# Traefik - Log Level (DEBUG | INFO | WARN | ERROR)
TRAEFIK_LOG_LEVEL=INFO
