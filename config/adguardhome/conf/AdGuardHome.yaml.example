
# Configuration version : v1.0
# Exemple de configuration AdGuard Home
# Copiez ce fichier en AdGuardHome.yaml pour personnaliser la config
# Voir la documentation officielle : https://github.com/AdguardTeam/AdGuardHome/wiki/Configuration

bind_host: 0.0.0.0
bind_port: 3000

# --- Authentification administrateur ---
users:
  - name: replace_with_admin_username
    password: replace_with_admin_password
# IMPORTANT : ne commitez pas de vrai mot de passe dans ce fichier d'exemple.
# Définissez le compte admin lors du premier lancement ou remplacez ces placeholders
# uniquement dans votre environnement de déploiement.
# (Menu Paramètres → Général → Utilisateurs)

# ... autres options à compléter selon vos besoins ...
