# ============================================================
# Pi-hole – Résolutions DNS locales (exemple lab)
# Domaine   : lab.local
# Réseau    : 192.168.10.0/24
#
# Format : <IP>   <hostname>
#
# Ces enregistrements sont chargés par dnsmasq et sont
# PRIORITAIRES sur le DNS amont (upstream).
# Redémarrez Pi-hole après modification :
#   docker compose restart pihole
# ============================================================

# ── Infrastructure du lab ─────────────────────────────────


# gw.lab.local — Passerelle / Routeur (192.168.10.1)
# Passerelle principale du lab.
192.168.10.1   gw.lab.local

# media.lab.local — Hub multimédia (192.168.10.20)
# Serveur multimédia centralisé du lab.
192.168.10.20  media.lab.local

# host1.lab.local — Serveur principal (192.168.10.10)
# Héberge Pi-hole, Squid et Traefik.
192.168.10.10  host1.lab.local


# ── Services exposés par Traefik sur host1.lab.local ──────────────
# Ces entrées doivent correspondre aux labels Host(…) du docker-compose.

# Tableau de bord Traefik
192.168.10.10    traefik.lab.local

# Interface d'administration Pi-hole
192.168.10.10    pihole.lab.local

# Point d'entrée proxy (documentation / convenience alias)
192.168.10.10    proxy.lab.local

# ── Ajoutez vos entrées supplémentaires ci-dessous ───────────
# Exemple :
# 192.168.10.20    grafana.lab.local
# 192.168.10.20    prometheus.lab.local
