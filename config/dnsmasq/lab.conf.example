# Exemple de configuration dnsmasq pour un lab générique
# Fichier : /etc/dnsmasq.d/99-lab.conf (dans Pi-hole)
#
# Ce fichier est un exemple. Il sera généré dynamiquement lors de l'installation.
#
# Domaine local
# domain=lab.local
# local=/lab.local/
#
# TTL des réponses locales
# local-ttl=300
#
# Résolution inverse (PTR) pour le sous-réseau
# rev-server=192.168.10.0/24,127.0.0.1
#
# Enregistrements PTR explicites (exemple)
# ptr-record=1.10.168.192.in-addr.arpa,gw.lab.local
# ptr-record=20.10.168.192.in-addr.arpa,media.lab.local
# ptr-record=10.10.168.192.in-addr.arpa,host1.lab.local
#
# SRV records (optionnel)
# srv-host=_http._tcp.lab.local,traefik.lab.local,80
# srv-host=_https._tcp.lab.local,traefik.lab.local,443
