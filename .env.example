DNS_ENGINE=adguardhome
# ============================================================
# Lab Example – Variables d'environnement
#
# Copiez ce fichier avant de démarrer la stack :
#   cp .env.example .env
#
# Infrastructure :
#   media.lab.local      192.168.10.20    (hub multimédia)
#   gw.lab.local         192.168.10.1     (passerelle)
#   host1.lab.local      192.168.10.10    (hôte de la stack)
# ============================================================

# ── Fuseau horaire ───────────────────────────────────────────
TZ=Europe/Paris

# ── Réseau du lab ─────────────────────────────────────────
# IP de host1.lab.local, hôte Docker de la stack
SERVER_IP=192.168.10.10

# Domaine DNS utilise par les URL de la stack.
# Pour Let's Encrypt DNS-01, ce domaine doit etre un domaine public enregistre que vous controlez.
# Pour un usage uniquement local, vous pouvez utiliser un domaine interne, mais il faudra alors
# utiliser un certificat auto-signe ou mkcert au lieu de Let's Encrypt.
# Exemple public : lab.example.com
# Exemple interne : lab.local
DOMAIN=replace_with_your_domain

# Let's Encrypt (ACME)
# Adresse email de contact pour Let's Encrypt
ACME_EMAIL=replace_with_your_email@example.com

# Cloudflare API Token (Zone DNS:Edit sur votre zone uniquement)
# Ne jamais commiter un vrai token dans le dépôt.
CF_DNS_API_TOKEN=replace_with_your_cloudflare_api_token



# ── Squid ────────────────────────────────────────────────────
# Port TCP sur lequel Squid écoute les clients proxy
SQUID_PORT=3128

# ── Traefik ──────────────────────────────────────────────────
# Niveau de log du reverse proxy (DEBUG | INFO | WARN | ERROR)
TRAEFIK_LOG_LEVEL=INFO
