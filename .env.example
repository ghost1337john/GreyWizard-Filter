# ============================================================
# GreyHaven Lab – Variables d'environnement
#
# Copiez ce fichier avant de démarrer la stack :
#   cp .env.example .env
#
# Infrastructure :
#   palantir.greyhaven   192.168.1.2    (hub multimédia)
#   gandalf.greyhaven    192.168.1.254  (passerelle)
#   carcharoth.greyhaven 192.168.1.3   (hôte de la stack)
# ============================================================

# ── Fuseau horaire ───────────────────────────────────────────
TZ=Europe/Paris

# ── Réseau GreyHaven ─────────────────────────────────────────
# IP de carcharoth.greyhaven, hôte Docker de la stack
SERVER_IP=192.168.1.3

# Domaine DNS interne du lab (sans le point final)
TRAEFIK_DOMAIN=greyhaven

# ── Pi-hole ──────────────────────────────────────────────────
# Mot de passe de l'interface web Pi-hole (obligatoire, ne laissez pas 'changeme')
# Si vous laissez 'changeme', le script d'installation vous demandera d'en saisir un avant de continuer.
PIHOLE_WEBPASSWORD=changeme

# DNS upstream utilisé par Pi-hole pour les domaines non locaux.
# Par défaut : Quad9 primaire + secondaire (recommandé sécurité).
# Format attendu : IP;IP;IP (séparateur point-virgule).
#
# Presets anti-pub / anti-trackers :
#   Quad9 (malware/phishing)      : 9.9.9.9;149.112.112.112
#   AdGuard DNS (ads/trackers)    : 94.140.14.14;94.140.15.15
#   Control D - Ads/Malware       : 76.76.2.2;76.76.10.2
#   Mullvad DNS - Ad/Tracker      : 194.242.2.4;194.242.2.5
#
# Tu peux aussi mixer, par exemple :
#   PIHOLE_DNS=9.9.9.9;149.112.112.112;94.140.14.14;94.140.15.15
PIHOLE_DNS=9.9.9.9;149.112.112.112

# ── Squid ────────────────────────────────────────────────────
# Port TCP sur lequel Squid écoute les clients proxy
SQUID_PORT=3128

# ── Traefik ──────────────────────────────────────────────────
# Niveau de log du reverse proxy (DEBUG | INFO | WARN | ERROR)
TRAEFIK_LOG_LEVEL=INFO
