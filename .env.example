DNS_ENGINE=adguardhome
# ============================================================
# Lab Example – Variables d'environnement
#
# Copiez ce fichier avant de démarrer la stack :
#   cp .env.example .env
#
# Infrastructure :
#   media.lab.local      192.168.10.20    (hub multimédia)
#   gw.lab.local         192.168.10.1     (passerelle)
#   host1.lab.local      192.168.10.10    (hôte de la stack)
# ============================================================

# ── Fuseau horaire ───────────────────────────────────────────
TZ=Europe/Paris

# ── Réseau du lab ─────────────────────────────────────────
# IP de host1.lab.local, hôte Docker de la stack
SERVER_IP=192.168.10.10

# Domaine DNS interne du lab (sans le point final)
DOMAIN=lab.local



# ── Squid ────────────────────────────────────────────────────
# Port TCP sur lequel Squid écoute les clients proxy
SQUID_PORT=3128

# ── Traefik ──────────────────────────────────────────────────
# Niveau de log du reverse proxy (DEBUG | INFO | WARN | ERROR)
TRAEFIK_LOG_LEVEL=INFO
